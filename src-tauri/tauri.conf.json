{
  "productName": "Cafe POS & Credit Ledger",
  "version": "0.1.0",
  "identifier": "com.cafe.pos.creditledger",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "cross-env TAURI_BUILD=true npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cafe POS & Credit Ledger",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
